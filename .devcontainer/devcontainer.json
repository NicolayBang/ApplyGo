{
  "name": "ApplyPilot Codespaces",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
  },
  "postCreateCommand": "cd backend && python -m pip install --upgrade pip && python -m pip install -e .[dev]",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-azuretools.vscode-docker"
      ]
    }
  },
  "remoteEnv": {
    "PYTHONUNBUFFERED": "1"
  }
}
